# Copy to `.env` and fill in. Never commit real keys.

# --- LLM provider ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.6-luna
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Pricing ---
OPENAI_MODEL_INPUT_PRICE_PER_1M=1
OPENAI_MODEL_OUTPUT_PRICE_PER_1M=6
OPENAI_EMBED_PRICE_PER_1M=0.02

# --- Vector store: Pinecone serverless ---
PINECONE_API_KEY=
PINECONE_INDEX=knowledge-assistant
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Ingestion ---
CHUNK_MAX_CHARS=500
